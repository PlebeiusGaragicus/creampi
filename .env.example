# Unified Creampi Configuration

# Server runtime
HOST=127.0.0.1
PORT=5173
# DATA_DIR defaults to ~/.local/share/creampi (outside repo, survives git pull).
# Uncomment to override:
# DATA_DIR=./data

# LM Studio (server-side inference, model discovery, and computer mode)
# All LLM calls go through the server -- the browser never contacts LM Studio directly.
LM_STUDIO_BASE_URL=http://localhost:1234
LM_STUDIO_DEFAULT_MODEL=
LM_STUDIO_API_KEY=

# Sandbox mode: direct | nspawn
SANDBOX_MODE=direct
NSPAWN_BASE_IMAGE=/var/lib/machines/creampi-base
NSPAWN_BRIDGE=creampi
CUBICLES_DIR=~/cubicles

# Optional integrations
NTFY_BASE_URL=http://127.0.0.1:8090
NTFY_TOPIC=creampi
STRFRY_RELAY_URL=wss://relay.abvstudio.net
GITEA_BASE_URL=https://git.abvstudio.net
